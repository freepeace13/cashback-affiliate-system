{
    "name": "freepeace13/cashback-affiliate-system",
    "description": "A backend architecture demo for building a cashback affiliate platform similar to Rakuten or TopCashback.",
    "author": {
        "name": "Kin Basco",
        "email": "freepeace13@gmail.com"
    },
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^13.1",
        "illuminate/validation": "^13.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
